{
  "name": "updatepatch",
  "version": "1.1.0",
  "description": "Undo/redo for any mutable state. Works with plain objects, classes, arrays, Maps, and Sets — no immutability required.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "keywords": [
    "undo",
    "redo",
    "patch",
    "undo-redo",
    "json-patch",
    "immer",
    "proxy",
    "mutation",
    "state",
    "history",
    "map",
    "set",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pie6k/updatepatch.git"
  },
  "bugs": {
    "url": "https://github.com/pie6k/updatepatch/issues"
  },
  "homepage": "https://github.com/pie6k/updatepatch#readme",
  "author": "pie6k",
  "scripts": {
    "build": "vite build && cp dist/index.d.ts dist/index.d.cts",
    "test": "jest --config jest.config.cjs",
    "lint": "tsc --noEmit",
    "prepublishOnly": "yarn build",
    "check:exports": "attw --pack .",
    "check:publint": "publint"
  },
  "packageManager": "yarn@4.5.3+sha512.3003a14012e2987072d244c720506549c1aab73ee728208f1b2580a9fd67b92d61ba6b08fe93f6dce68fd771e3af1e59a0afa28dd242dd0940d73b95fedd4e90",
  "license": "MIT",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "publint": "^0.3.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.0"
  }
}
